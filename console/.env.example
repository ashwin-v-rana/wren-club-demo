# The Wren — Front Desk Console — server-only environment.
# Copy to .env.local and fill in. NEVER commit .env.local.
#
# Hard rule: the browser never talks to Supabase. There are NO NEXT_PUBLIC_*
# Supabase vars on purpose — all data access is server-side via the service role.

# Supabase project (hotel/club project: gqfrpmzwdlmscdascyqm)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key

# Console admin auth (staff login). Generate a long random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
BCRYPT_ROUNDS=10
